{
  "version": "1.0",
  "mcp_name": "Danish Energy Regulation MCP",
  "tests": [
    {
      "id": "dk-energy-001",
      "category": "search",
      "description": "Search regulations for 'energi'",
      "tool": "dk_energy_search_regulations",
      "input": { "query": "energi" },
      "assertions": { "result_not_empty": true, "min_results": 1 }
    },
    {
      "id": "dk-energy-002",
      "category": "data_retrieval",
      "description": "Get regulation by reference (BEK nr 1310)",
      "tool": "dk_energy_get_regulation",
      "input": { "reference": "BEK nr 1310 af 24/11/2023" },
      "assertions": { "result_not_empty": true }
    },
    {
      "id": "dk-energy-003",
      "category": "search",
      "description": "Search grid codes for 'tilslutning'",
      "tool": "dk_energy_search_grid_codes",
      "input": { "query": "tilslutning" },
      "assertions": { "result_not_empty": true, "min_results": 1 }
    },
    {
      "id": "dk-energy-004",
      "category": "data_retrieval",
      "description": "Get grid code by document ID",
      "tool": "dk_energy_get_grid_code",
      "input": { "document_id": 2 },
      "assertions": { "result_not_empty": true }
    },
    {
      "id": "dk-energy-005",
      "category": "search",
      "description": "Search decisions for 'tarif'",
      "tool": "dk_energy_search_decisions",
      "input": { "query": "tarif" },
      "assertions": { "result_not_empty": true, "min_results": 1 }
    },
    {
      "id": "dk-energy-006",
      "category": "meta_tool",
      "description": "About tool returns server metadata",
      "tool": "dk_energy_about",
      "input": {},
      "assertions": { "result_not_empty": true }
    },
    {
      "id": "dk-energy-007",
      "category": "negative_test",
      "description": "Non-existent regulation reference handles gracefully",
      "tool": "dk_energy_get_regulation",
      "input": { "reference": "NONEXISTENT-REF-999" },
      "assertions": { "handles_gracefully": true }
    },
    {
      "id": "dk-energy-008",
      "category": "negative_test",
      "description": "Non-existent grid code ID handles gracefully",
      "tool": "dk_energy_get_grid_code",
      "input": { "document_id": 99999 },
      "assertions": { "handles_gracefully": true }
    },
    {
      "id": "dk-energy-009",
      "category": "search",
      "description": "Search regulations with regulator filter",
      "tool": "dk_energy_search_regulations",
      "input": { "query": "sikkerhed", "regulator": "sikkerhedsstyrelsen" },
      "assertions": { "result_not_empty": true, "min_results": 1 }
    },
    {
      "id": "dk-energy-010",
      "category": "search",
      "description": "Search regulations with type filter",
      "tool": "dk_energy_search_regulations",
      "input": { "query": "bekendtgorelse", "type": "bekendtgorelse" },
      "assertions": { "result_not_empty": true, "min_results": 1 }
    },
    {
      "id": "dk-energy-011",
      "category": "search",
      "description": "Search grid codes by code_type",
      "tool": "dk_energy_search_grid_codes",
      "input": { "query": "marked", "code_type": "market_regulation" },
      "assertions": { "result_not_empty": true }
    },
    {
      "id": "dk-energy-012",
      "category": "cross_reference",
      "description": "Search decisions for methodology approvals",
      "tool": "dk_energy_search_decisions",
      "input": { "query": "metode", "decision_type": "methodology" },
      "assertions": { "result_not_empty": true, "min_results": 1 }
    }
  ]
}
